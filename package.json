{
  "name": "desktop-assistant",
  "version": "1.0.0",
  "description": "Tiny AI companions that live on your taskbar — cross-platform port of lil-agents",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox --disable-dev-shm-usage",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "electron": "^36.3.1",
    "ics": "^3.8.1"
  },
  "build": {
    "appId": "com.desktop-assistant.app",
    "productName": "Desktop Assistant",
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
